# Example environment variables only.
# Do not put real secrets in this file.

NODE_ENV=production
PORT=4000

DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=shopee_dashboard

JWT_SECRET=your_jwt_secret_here

SHOPEE_PARTNER_ID=your_partner_id_here
SHOPEE_PARTNER_KEY=your_partner_key_here
SHOPEE_REDIRECT_URL=https://your-domain.com/api/auth/shopee/callback

GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_RECEIPT_SHEET_NAME=입고관리
GOOGLE_SKU_COMPOSITION_SHEET_NAME=상품구성표
